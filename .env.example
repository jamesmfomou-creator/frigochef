# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-side only, never expose

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...         # sans clé → mode mock automatique

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...      # Stripe Dashboard → Développeurs → Clés API
STRIPE_WEBHOOK_SECRET=whsec_...    # Stripe Dashboard → Développeurs → Webhooks
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_ID=price_...          # Stripe Dashboard → Produits → ID du prix mensuel

# ── Google Analytics ──────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX  # analytics.google.com → Admin → Flux de données

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://frigochef.vercel.app
